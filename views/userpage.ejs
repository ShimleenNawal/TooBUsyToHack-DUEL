<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Page</title>

    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/userpage.css">
</head>
<body data-userid="<%= userid %>">
    <h2 class ="type-writer"> Welcome, <%= userid %></h2>
    <div class="content-layout">
    <!-- Left column: buttons -->
    <div class="button-column">
        <button class="btn-tasks" id="taskButton">Tasks</button>
        <button class="btn-rivals" id="rivalButton">Rival</button>
    </div>

    <!-- Right column: leaderboard -->
    <div class="leaderboard-column">
        <h2 class="title">Leaderboard</h2>
        <table class="leaderboard">
        <thead>
            <tr>
            <th>Rank</th>
            <th>UserID</th>
            <th>Medals</th>
            </tr>
        </thead>
        <tbody>
            <% topStudents.forEach((student, index) => { %>
            <tr>
            <td><%= index + 1 %></td>
            <td><%= student.id %></td>
            <td><%= student.medals %></td>
            </tr>
            <% }) %>
        </tbody>
        </table>
    </div>
    </div>

    <!-- Modal Structure for Tasks -->
    <div class="modal" id="taskModal">
    <div class="modal-content">
        <div class="modal-header">
        <span class="task-label">Task</span>
        <span class="time-left" id="timeLeft"
                data-deadline="<%= ongoingTask ? ongoingTask.deadline.toISOString() : '' %>">
            Time Left: 00:00
        </span>
        <button class="close-btn" id="closeModal">&times;</button>
        </div>
        <% if (ongoingTask && taskDetails) { %>
        <form id="taskForm" enctype="multipart/form-data">
            <div class="task-box"><%= ongoingTask.taskName %></div>
            <a href="/<%= taskDetails.attachedFile %>" download class="download-attachment">Download Attachment</a>
            <label for="fileUpload" class="custom-file-upload">Add File</label>
            <input type="file" id="fileUpload" name="zipFile" />
            <button type="submit">Submit</button>
        </form>
        <% } else { %>
        <p>No active task assigned.</p>
        <% } %>
    </div>
    </div>

    <!-- Modal Structure for Rival -->
    <div class="modal" id="rivalModal">
    <div class="modal-content">
        <div class="modal-header">
        <span class="task-label">Rival</span>
        <span class="time-left" id="rivalTimeLeft"
                data-deadline="<%= rivalDeadline || '' %>">00:00</span>
        <button class="close-btn" id="closeRivalModal">&times;</button>
        </div>
        <div class="rival-info">
        <p>Your Rival is:</p>
        <h2><%= rivalId || "No rival assigned" %></h2>
        <p>Status:</p>
        <h3><%= rivalSubmitted ? "Submitted" : "Not Submitted" %></h3>
        </div>
    </div>
    </div>

    <div class="settings-icon" id="settingsButton">
        <i class="material-icons" style="font-size: 88px;">settings</i> <!-- Increased the font size of the icon -->
    </div>

    <div class="modal" id="settingsModal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="task-label">Settings</span>
                <button class="close-btn" id="closeSettingsModal">&times;</button>
            </div>
            <form id="settingsForm">
                <label for="department">Department</label>
                <select id="department" name="department">
                    <option value="" selected>Select Department</option>
                    <option value="cs" <%= department === 'cs' ? 'selected' : '' %>>Computer Science</option>
                    <option value="math" <%= department === 'math' ? 'selected' : '' %>>Mathematics</option>
                    <option value="physics" <%= department === 'physics' ? 'selected' : '' %>>Physics</option>
                </select>

                <label for="year">Year</label>
                <select id="year" name="year">
                    <option value="" selected>Select Year</option>
                    <option value="1" <%= year_of_study === '1' ? 'selected' : '' %>>1</option>
                    <option value="2" <%= year_of_study === '2' ? 'selected' : '' %>>2</option>
                    <option value="3" <%= year_of_study === '3' ? 'selected' : '' %>>3</option>
                    <option value="4" <%= year_of_study === '4' ? 'selected' : '' %>>4</option>
                </select>

                <button type="submit">Save</button>
            </form>
        </div>
    </div>

    <script src="/javascripts/userpage.js"></script>
</body>
</html>